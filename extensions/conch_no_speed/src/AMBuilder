import os

projectName = 'conch_no_speed'

project = builder.LibraryProject(projectName)
safetyhookRoot = os.path.join(Extension.sm_root, 'public', 'safetyhook')
project.sources += [
  'extension.cpp',
  os.path.join(Extension.sm_root, 'public', 'CDetour', 'detours.cpp'),
  os.path.join(safetyhookRoot, 'src', 'allocator.cpp'),
  os.path.join(safetyhookRoot, 'src', 'easy.cpp'),
  os.path.join(safetyhookRoot, 'src', 'inline_hook.cpp'),
  os.path.join(safetyhookRoot, 'src', 'mid_hook.cpp'),
  os.path.join(safetyhookRoot, 'src', 'utility.cpp'),
  os.path.join(safetyhookRoot, 'src', 'vmt_hook.cpp'),
  os.path.join(safetyhookRoot, 'zydis', 'Zydis.c'),
]

if os.path.isfile(os.path.join(builder.currentSourcePath, 'sdk', 'smsdk_ext.cpp')):
  project.sources += [os.path.join('sdk', 'smsdk_ext.cpp')]
else:
  project.sources += [os.path.join(Extension.sm_root, 'public', 'smsdk_ext.cpp')]

for sdk_name in Extension.sdks:
  sdk = Extension.sdks[sdk_name]
  if sdk['name'] != 'tf2':
    continue

  for cxx in builder.targets:
    if cxx.target.arch not in sdk['platforms'][cxx.target.platform]:
      continue

    binary = Extension.HL2ExtConfig(project, builder, cxx,
                                    projectName + '.ext.' + sdk['extension'], sdk)
    if cxx.target.platform == 'linux':
      binary.sources += [os.path.join(safetyhookRoot, 'src', 'os.linux.cpp')]
    binary.compiler.includes += [
      os.path.join(Extension.sm_root, 'public'),
      os.path.join(safetyhookRoot, 'zydis'),
    ]
    binary.compiler.cxxincludes += [
      os.path.join(safetyhookRoot, 'include'),
    ]
    source_root = os.path.abspath(os.path.join(builder.currentSourcePath, '..', '..'))
    prefix_map = '-ffile-prefix-map={}=.'.format(source_root)
    binary.compiler.cflags += [prefix_map]
    binary.compiler.cxxflags += [prefix_map]
    if binary.compiler.behavior == 'gcc':
      binary.compiler.cxxflags += ['-Wno-invalid-offsetof']
    binary.compiler.defines += ['HAVE_STRING_H']

Extension.extensions += builder.Add(project)
